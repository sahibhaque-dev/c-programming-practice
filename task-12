#include<stdio.h>
int main (){

    int n= 2;

    int arr[n][n];
    int arr2[n][n];
printf("\n");
        printf("Input elements in the first matrix:\n ");
    for (int i =0;i<n;i++){
               for (int j =0;j<n;j++){
       printf(" Element - [%d],[%d] : ",i,j);
       scanf("%d",&arr[i][j]);
               }
    }
    for (int i =0;i<n;i++){
               for (int j =0;j<n;j++){
                    arr2[i][j]=0;

                    arr2[i][j]+= arr[j][i];
               }
    }
  printf("\n");
     printf("The transpose of a matrix is:\n");  
    for (int i =0;i<n;i++){
               for (int j =0;j<n;j++){
       printf(" %d \t",arr2[i][j]);
               }
                    printf("\n");
    }
return 0 ;
}
