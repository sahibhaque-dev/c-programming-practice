#include<stdio.h>
int main (){

    int n =6;
    int arr[n];
    for (int i =0;i<n;i++){
       printf("enter %d number = ",i+1);
       scanf("%d",&arr[i]);
    }
     int max= arr[0];
    for (int i =1;i<n;i++){
        if(arr[i]>max){
            max = arr[i];
        }
    }
           printf("Max = %d",max);

    int max2=-99999;
    for (int i =1;i<n;i++){
        if((arr[i]>max2)&&(arr[i]!=max)){
            max2= arr[i];
        }
    }
               printf("\n2nd Max = %d",max2);

return 0 ;
}
